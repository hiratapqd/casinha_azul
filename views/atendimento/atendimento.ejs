<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Atendimento</title>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>

<h2>Atendimento <%= (nomeTerapia || tipo).toString() %></h2>

<form class="form-container" action="/atendimento/<%= tipo %>" method="POST">

<label>Data</label>
<input type="date" name="data" required>

<label>CPF</label>
<input type="text" id="cpf_assistido" name="cpf_assistido" required>

<label>Nome</label>
<input type="text" name="nome_assistido" readonly>

<label>Voluntário</label>
<input type="text" name="voluntario">

<label>Observações</label>
<textarea name="observacoes"></textarea>

<button type="submit">Salvar Atendimento</button>

</form>

<h3>Últimos atendimentos</h3>
<div id="container-historico"></div>

<script>

const tipo = "<%= tipo %>";
const cpfInput = document.getElementById("cpf_assistido");
const container = document.getElementById("container-historico");
const nomeInput = document.querySelector('input[name="nome_assistido"]');

cpfInput.addEventListener("blur", async () => {

  const cpf = cpfInput.value.trim();
  if (!cpf) return;

  const cacheBust = `?ts=${Date.now()}`;

  try {

    const resp = await fetch(`/api/historico/${tipo}/${cpf}${cacheBust}`);
    const payload = await resp.json();

    const historico = payload.historico || [];
    const assistido = payload.assistido || {};

    nomeInput.value = assistido.nome || "";

    if (!historico.length) {
      container.innerHTML = "Nenhum histórico encontrado.";
      return;
    }

    let html = "<ul>";

    historico.forEach(item => {

      const data = new Date(item.data).toLocaleString("pt-BR");

      html += `<li>${data} - ${item.voluntario}</li>`;

    });

    html += "</ul>";

    container.innerHTML = html;

  } catch(err) {

    console.error(err);
    container.innerHTML = "Erro ao carregar histórico";

  }

});


// SweetAlert salvar
const form = document.querySelector("form");

form.addEventListener("submit", async function(e){

  e.preventDefault();

  const body = new URLSearchParams(new FormData(form));

  const resp = await fetch(form.action, {
    method: "POST",
    headers: { "Content-Type": "application/x-www-form-urlencoded" },
    body
  });

  if(!resp.ok){
    Swal.fire("Erro","Erro ao salvar atendimento","error");
    return;
  }

  await Swal.fire("Sucesso","Atendimento salvo","success");

  window.location.href = `/atendimento/${tipo}`;

});

</script>

</body>
</html>
<%- include('../partials/footer') %>