<script>
// Função vital para ler os dias selecionados
function obterCheckboxes(nomeGrupo) {
    const selecionados = [];
    // Busca checkboxes marcadas que tenham o nome do grupo no ID ou Name
    const checkboxes = document.querySelectorAll(`input[type="checkbox"]:checked`);
    checkboxes.forEach(cb => {
        if (cb.id.includes(nomeGrupo) || (cb.name && cb.name.includes(nomeGrupo))) {
            selecionados.push(cb.value);
        }
    });
    return selecionados;
}

async function enviarFormulario() {
    // Monta o objeto exatamente como o server.js e o Voluntario.js esperam
    const dados = {
        nome: document.getElementById('nome').value,
        cpf: document.getElementById('cpf').value,
        telefone: document.getElementById('telefone').value,
        email: document.getElementById('email').value,
        mediunidade: document.getElementById('mediunidade').value,
        esta_ativo: "Sim",
        forceUpdate: document.getElementById('forceUpdate').value === 'true',
        
        // Captura manual de cada array de disponibilidade
        voluntario_apometria_dias: obterCheckboxes('apometria'),
        voluntario_reiki_dias: obterCheckboxes('reiki'),
        voluntario_auriculo_dias: obterCheckboxes('auriculo'),
        voluntario_maos_dias: obterCheckboxes('maos'),
        voluntario_homeopatia_dias: obterCheckboxes('homeopatia'),
        voluntario_cantina_dias: obterCheckboxes('cantina'),
        voluntario_mesa_dias: obterCheckboxes('mesa'),
        voluntario_passe_dias: obterCheckboxes('passe') // <--- O Passe entra aqui
    };

    if (!dados.nome || !dados.cpf) {
        Swal.fire('Erro', 'Nome e CPF são obrigatórios!', 'error');
        return;
    }

    try {
        const resposta = await fetch('/mediun/novo', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(dados)
        });

        const resultado = await resposta.json();

        if (resultado.status === 'conflito') {
            Swal.fire({
                title: 'CPF já cadastrado!',
                text: "Deseja atualizar os dados?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sim, atualizar!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('forceUpdate').value = 'true';
                    enviarFormulario(); // Reenvia com a flag de atualização
                }
            });
        } else if (resultado.status === 'sucesso') {
            Swal.fire('Sucesso!', 'Dados gravados com sucesso.', 'success')
                .then(() => window.location.href = '/'); // Redireciona só após o OK
        }
    } catch (err) {
        console.error("Erro no envio:", err);
        Swal.fire('Erro', 'Falha ao conectar com o servidor.', 'error');
    }
}
</script>

</main>
