<html>
    <link rel="stylesheet" href="/styles/styles.css">
    <%- include('../partials/header') %>

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Relatório de Assistidos</title>

<body>
<main style="padding: 20px;">
    <h1>Relatório Geral de Assistidos</h1>
    <p>Total de cadastros: <strong><%= assistidos.length %></strong> </p>

    <table border="1" style="width:100%; border-collapse: collapse; margin-top: 20px;">
        <thead>
            <tr style="background-color: #f2f2f2;">
                <th style="padding: 10px; text-align: left;">Nome</th> 
                <th style="padding: 10px; text-align: left;">CPF</th> 
                <th style="padding: 10px; text-align: left;">Telefone</th>
                <th style="padding: 10px; text-align: left;">E-mail</th> 
                <th style="padding: 10px; text-align: left;">Tratamentos Realizados</th>
            </tr>
        </thead>
        <tbody>
            <% assistidos.forEach(pessoa => { %> 
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px;"><%= pessoa.nome %></td>
                    <td style="padding: 10px;"><%= pessoa.cpf %></td> 
                    <td style="padding: 10px;"><%= pessoa.telefone %></td> 
                    <td style="padding: 10px;"><%= pessoa.email %></td>
                    <td style="padding: 10px;">
                        <div style="display: flex; flex-wrap: wrap; gap: 5px;">
                            <% if (pessoa.tratamentos && pessoa.tratamentos.length > 0) { %>
                                <% pessoa.tratamentos.forEach(tratamento => { %>
                                    <span style="background-color: #e0e7ff; color: #4338ca; padding: 2px 8px; border-radius: 10px; font-size: 11px; border: 1px solid #c7d2fe; white-space: nowrap;">
                                        <%= tratamento %>
                                    </span>
                                <% }) %>
                            <% } else { %>
                                <small style="color: #999;">Nenhum histórico</small>
                            <% } %>
                        </div>
                    </td>
                </tr>
            <% }) %> 
        </tbody>
    </table>
</main>
</body>
</html>
<%- include('../partials/footer') %>