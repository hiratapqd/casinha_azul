<%- include('partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">
<main class="hero">
    <h1>Solicitação de Atendimento Apometrico</h1>
    <form action="/solicitacao_atendimento" method="POST" class="form-container">
        <div class="form-group" style="flex: 1;">
            <label for="data">Data do Atendimento:</label>
            <input type="date" id="data" name="data" 
        value="<%= new Date().toLocaleDateString('en-CA') %>" required>
        </div>

        </div><br>
        <div class="form-group" style="flex: 2;">
            <label for="numero">Número do Atendimento:</label>
            <input type="text" id="numero" name="numero" required>
        </div><br>
        <div class="form-group" style="flex: 1;"> 
            <label for="nome_atendido">Nome de quem será atendido:</label>
            <input type="text" id="nome_atendido" name="nome_atendido" required>
        </div><br>
        <div class="form-group" style="flex: 2;">
            <label for="cpf_assistido">CPF do Assistido:</label>
            <input type="text" id="cpf_assistido" name="cpf_assistido" required>
        </div><br>

        <div class="form-group" style="flex: 1;">
            <label for="sexo">Sexo:</label>
            <input type="text" id="sexo" name="sexo" required>
        </div><br>
        <div class="form-group" style="flex: 2;">
            <label for="idade">Idade:</label>
            <input type="text" id="idade" name="idade" required>
        </div> <br>    
        <div class="form-group" style="flex: 3;">
            <label for="cidade">Religião:</label>
            <input type="text" id="religiao" name="religiao" required>
        </div>  <br>  
        <div class="form-group" style="flex: 1;">
            <label for="cidade">Cidade:</label>
            <input type="text" id="cidade" name="cidade" required>
        </div>    <br>
        <div class="form-group" style="flex: 2;">
            <label for="estado">UF:</label>
            <input type="text" id="estado" name="estado" required>
        </div><br>
        <div class="form-group" style="flex: 1;">
                <label for="email">email:</label>
                <input type="email" id="email" name="email">
        </div><br>
        <div class="form-group" style="flex: 2;">
            <label for="num_atendimento">Sendo atendido pela:</label>
            <select id="num_atendimento" name="num_atendimento" required>
                <option value="Primeira vez" selected>Primeira vez</option>
                <option value="Segunda vez">Segunda vez</option>
                <option value="Terceira vez">Terceira vez</option>
                <option value="Quarta vez">Quarta vez</option>
                <option value="Quinta vez">Quinta vez</option>
                <option value="mais vezes">Já passei mais vezes</option>
            </select>
        </div><br>
        <div class="form-group">
            <label for="queixa">Breve descrição do queixa/motivo:</label>
            <textarea id="queixa" name="queixa" rows="4"></textarea>
        </div><br>
        <div class="form-group">
            <label for="subir_escada">Pode subir escada:</label>
            <select id="subir_escada" name="subir_escada" required>

                <option value="Sim">Sim</option>
                <option value="Não">Não</option>
            </select>
        </div>
        <br>
        <br>
        <button type="submit" class="btn-enviar">Registrar Solicitação</button>
    </form>
</main>